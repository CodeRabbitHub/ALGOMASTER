# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=algomaster
POSTGRES_PASSWORD=algomaster_secret
POSTGRES_DB=algomaster
DATABASE_URL=postgresql+asyncpg://algomaster:algomaster_secret@db:5432/algomaster

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_secret_key_32chars
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:5173","http://localhost:3000"]
CODE_RUNNER_URL=http://code-runner:5000

# ── OpenAI (add your key here) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
